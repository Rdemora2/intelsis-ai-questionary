generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Lead {
  id           String   @id @default(cuid())
  fullName     String   @map("full_name")
  company      String
  email        String
  phone        String
  jobTitle     String   @map("job_title")
  companySize  String   @map("company_size")
  motivator    String
  sapModules   String   @map("sap_modules") // JSON array stored as string
  challenges   String
  demoInterest Boolean  @default(false) @map("demo_interest")
  techHelp     Boolean  @default(false) @map("tech_help")
  techHelpText String?  @map("tech_help_text")
  consent      Boolean
  createdAt    DateTime @default(now()) @map("created_at")

  @@map("leads")
}
